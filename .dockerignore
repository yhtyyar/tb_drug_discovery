# Prevent Docker build cache issues
# Force fresh builds

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
docs/
*.md
*.rst

# Data (mounted as volume)
data/raw/
data/processed/*.csv
data/processed/*.json

# Models (mounted as volume)
models/*.pt
models/*.pkl
models/*.joblib

# Logs
logs/
*.log

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# MLflow
mlruns/
mlartifacts/

# Temporary files
*.tmp
*.bak
*.cache
